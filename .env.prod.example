# =============================================================================
# MOTOGRAM — Üretim ortamı (.env.prod) ŞABLONU
# -----------------------------------------------------------------------------
# Otomatik doldurma: bash scripts/init-env-prod.sh <IP>
# Elle: cp .env.prod.example .env.prod && nano .env.prod && chmod 600 .env.prod
#
# --- deploy.sh sadece şu 8 alanı “dolu” ister (gerisi şifre değil / boş kalabilir) ---
#   (1) POSTGRES_PASSWORD   (2) REDIS_PASSWORD     (3) MINIO_ROOT_USER
#   (4) MINIO_ROOT_PASSWORD (5) JWT_ACCESS_SECRET  (6) JWT_REFRESH_SECRET
#   (7) INTERNAL_API_SHARED_SECRET  (8) NEXTAUTH_SECRET
# JWT üçlüsü: her biri en az 32 karakter → openssl rand -hex 32
# NEXTAUTH_SECRET: en az 16 karakter → openssl rand -base64 32
# Diğer şifre benzeri satırlar (GRAFANA_PASSWORD vb.) ZORUNLU DEĞİL.
#
# --- SUNUCU_IP --- Aşağıda 3 satırda geçer; hepsini kendi IP/domain ile değiştir.
#
# TLS yokken: NGINX_CONF=nginx.http.conf (değiştirme).
# =============================================================================

# --- TLS / nginx (IP ile ilk kurulum: http-only) ---
NGINX_CONF=nginx.http.conf

# --- Genel ağ (tarayıcı / mobil; şifre değil, URL) ---
CORS_ALLOWED_ORIGINS=http://SUNUCU_IP

# --- Postgres (şifre: sadece POSTGRES_PASSWORD) ---
POSTGRES_USER=motogram
POSTGRES_DB=motogram
POSTGRES_PASSWORD=

# --- Redis (şifre: REDIS_PASSWORD) ---
REDIS_PASSWORD=

# --- MinIO: MINIO_ROOT_USER = erişim anahtarı adı (şifre değil); MINIO_ROOT_PASSWORD = gizli anahtar ---
MINIO_ROOT_USER=motogramminio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=motogram-media

# --- API: uzun rastgele metin (şifre gibi sakla); hepsi ≥32 karakter ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_API_SHARED_SECRET=

# --- Web admin (URL + bir sır) ---
NEXT_PUBLIC_API_BASE_URL=http://SUNUCU_IP/v1
NEXTAUTH_URL=http://SUNUCU_IP
NEXTAUTH_SECRET=

# ========== AŞAĞISI BOŞ KALABİLİR (şimdilik doldurma zorunluluğu yok) ==========
# OAuth — boş: Apple/Google giriş uçları 503 (bilinçli)
APPLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# OTP — false: sadece e-posta/parola
OTP_AUTH_ENABLED=false

# Push / Sentry — prod’da sonra eklersin
FCM_CREDENTIALS_PATH=
APNS_AUTH_KEY_PATH=
SENTRY_DSN=

# Grafana — GRAFANA_PASSWORD boşsa Compose varsayılanı kullanır (changeme); sonra değiştir
GRAFANA_USER=admin
GRAFANA_PASSWORD=

SERVER_HOSTNAME=motogram-api
