# =============================================================================
# MOTOGRAM — Üretim ortamı (.env.prod) ŞABLONU
# -----------------------------------------------------------------------------
# Sunucuda (repo kökü):
#   cp .env.prod.example .env.prod
#   nano .env.prod
#   chmod 600 .env.prod
#
# Aşağıdaki "ZORUNLU" satırların hepsini gerçek değerlerle doldur.
# Sıra üretmek için (örnek; her biri için ayrı çalıştırıp yapıştır):
#   openssl rand -hex 16     # kısa parolalar (MinIO user hariç — ayrı kural)
#   openssl rand -hex 32     # POSTGRES_PASSWORD, REDIS_PASSWORD, MINIO_ROOT_PASSWORD
#   openssl rand -hex 32     # JWT_ACCESS_SECRET (API Zod: min 32 karakter)
#   openssl rand -hex 32     # JWT_REFRESH_SECRET (min 32)
#   openssl rand -hex 32     # INTERNAL_API_SHARED_SECRET (min 32)
#   openssl rand -base64 32 # NEXTAUTH_SECRET
#
# TLS sertifikan yokken mutlaka:
#   NGINX_CONF=nginx.http.conf
# Aksi halde varsayılan nginx.prod.conf sertifika dosyası ister.
# =============================================================================

# --- TLS / nginx (IP ile ilk kurulum: http-only) ---
NGINX_CONF=nginx.http.conf

# --- Genel ağ (tarayıcı / mobil isteklerinin geldiği adres) ---
# Tek IP ile deniyorsan örnek: http://SUNUCU_IP
# Birden fazla origin virgülle: https://api.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://SUNUCU_IP

# --- Postgres (Compose varsayılan kullanıcı/DB: motogram) ---
POSTGRES_USER=motogram
POSTGRES_DB=motogram
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=

# --- MinIO (S3 uyumlu medya; erişim anahtarları) ---
# MINIO_ROOT_USER: genelde en az 3 karakter; harf/rakam.
MINIO_ROOT_USER=motogramminio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=motogram-media

# --- API JWT + dahili fan-out (hepsi en az 32 karakter) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_API_SHARED_SECRET=

# --- Web admin (Next.js + NextAuth) ---
# Tarayıcının gördüğü API tabanı (/v1 ile biter). IP: http://1.2.3.4/v1
NEXT_PUBLIC_API_BASE_URL=http://SUNUCU_IP/v1
# NextAuth callback tabanı; nginx’te admin kök dizinle aynı host (çoğunlukla API ile aynı IP:80).
NEXTAUTH_URL=http://SUNUCU_IP
NEXTAUTH_SECRET=

# --- OAuth (boş bırakılabilir; boşsa ilgili uçlar 503) ---
APPLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# --- OTP (isteğe bağlı; true değilse e-posta/parola) ---
OTP_AUTH_ENABLED=false

# --- İsteğe bağlı: push / izleme ---
FCM_CREDENTIALS_PATH=
APNS_AUTH_KEY_PATH=
SENTRY_DSN=

# --- Grafana (boşsa admin / changeme) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# --- İsim / host etiketi (çoğunlukla varsayılan yeter) ---
SERVER_HOSTNAME=motogram-api
