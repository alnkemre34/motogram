{
  "name": "@motogram/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Motogram Shared Zod Schemas & Types (Frontend + Backend SSOT) — Spec 5, 7.3.6",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "import": "./dist/schemas/*.mjs",
      "require": "./dist/schemas/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo \"[@motogram/shared] lint skipped - typecheck covers Zod schemas\" && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@motogram/config-tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
