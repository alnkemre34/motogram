{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Motogram Expo / React Native",
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "allowJs": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "types": ["react-native", "jest"]
  }
}
