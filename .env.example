# =============================================================================
# MOTOGRAM — Ornek Cevresel Degiskenler (Spec 9.5 geregi)
# Hicbir gercek deger bu dosyaya yazilmaz. Gercek degerler .env dosyasinda
# tutulur ve .gitignore ile commit edilmez.
# =============================================================================

# -------- Ortak --------
NODE_ENV=development

# -------- Backend (apps/api) — Spec 3.1 + fail-fast env --------
API_PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/motogram?schema=public
REDIS_URL=redis://localhost:6379/0

# JWT — en az 32 karakter (Zod fail-fast)
JWT_ACCESS_SECRET=dev_access_secret_must_be_at_least_32_characters_long__
JWT_REFRESH_SECRET=dev_refresh_secret_must_be_at_least_32_characters_long_

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Internal fanout (Faz 7) — en az 32 karakter
INTERNAL_API_SHARED_SECRET=dev_internal_shared_secret_32_chars_minimum_ok
SERVER_HOSTNAME=api-local

# CORS — virgulle ayirilmis origin listesi
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# MinIO / S3 (Spec 3.4)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=motogram-media
MINIO_USE_SSL=false

# Sign in with Apple / Google (Spec 9.2 — `aud` doğrulaması; boşsa OAuth uçları 503)
APPLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# Opsiyonel
SENTRY_DSN=
# R12: Üretimde 72h bake sonrası strict — DEPLOY_RUNBOOK.md § "R12 — Zod strict kapanış"
ZOD_RESPONSE_STRICT=false
DISABLE_BULLMQ_WORKER=false

# B-16 — Telefon OTP (`POST /v1/auth/otp/*`). true yapınca OTP + `GET /v1/auth/capabilities` aynı bayrağı yansıtır.
OTP_AUTH_ENABLED=false

# -------- Mobile (apps/mobile-native) — react-native-config + src/config/env.ts --------
# Android: ENVFILE=.env.development ./gradlew …  iOS: xcconfig / scheme — RN Config dokümantasyonu
# API tabanı /v1 ile biter; WS aynı origin’de path’siz (boşsa env.ts apiUrl’den türetir)
API_URL=http://localhost:3000/v1
WS_URL=http://localhost:3000
# MapLibre style JSON URL; boş bırakılırsa MapLibre demo tile (demotiles.maplibre.org)
MAP_STYLE_URL=
SENTRY_DSN=
# true ise istemci şema sıkılığı (geliştirme)
STRICT_SCHEMA=false
# Google Sign-In (Id token); boşsa ilgili CTA gizlenir
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# -------- Web Admin (apps/web-admin) — Spec 5.4 --------
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
