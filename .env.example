# cp .env.example .env
# Postgres+Redis (lokal): docker compose -f docker-compose.dev.yml up -d
# DATABASE_URL = postgresql://KULLANICI:SIFRE@HOST:5432/VERITABANI?schema=public

NODE_ENV=development

DATABASE_URL=postgresql://motogram:motogram_dev_password@localhost:5432/motogram?schema=public
REDIS_URL=redis://localhost:6379/0
API_PORT=3000

JWT_ACCESS_SECRET=dev_access_secret_must_be_at_least_32_characters_long__
JWT_REFRESH_SECRET=dev_refresh_secret_must_be_at_least_32_characters_long_
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

INTERNAL_API_SHARED_SECRET=dev_internal_shared_secret_32_chars_minimum_ok
SERVER_HOSTNAME=api-local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=motogram-media
MINIO_USE_SSL=false

APPLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

SENTRY_DSN=
ZOD_RESPONSE_STRICT=false
DISABLE_BULLMQ_WORKER=false
OTP_AUTH_ENABLED=false

API_URL=http://localhost:3000/v1
WS_URL=http://localhost:3000
MAP_STYLE_URL=
STRICT_SCHEMA=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
