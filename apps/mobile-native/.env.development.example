# react-native-config — yerel kopya:  cp .env.development.example .env.development
# Android: ENVFILE=.env.development  (ör. cd android && ENVFILE=.env.development ./gradlew installDebug)
# IP/domain kendi VPS’ine göre değiştir.

API_URL=http://85.235.74.203/v1
WS_URL=http://85.235.74.203

# MapLibre — stil = tarayıcıda açılan bir Mapbox GL / MapLibre "style.json" URL'i.
# Boş bırakırsan uygulama env.ts içinde şu varsayılanı kullanır (anahtar gerekmez):
#   https://demotiles.maplibre.org/style.json
# Kendi stilin: MapTiler Cloud "Raster/Vector GL style URL", veya kendi host ettiğin style.json.
MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

STRICT_SCHEMA=false

# Google Sign-In (boş = CTA gizli)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

SENTRY_DSN=
