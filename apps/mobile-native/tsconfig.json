{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx", "babel.config.js", "metro.config.js", "jest.config.js"],
  "exclude": ["node_modules", "android", "ios"]
}
