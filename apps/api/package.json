{
  "name": "@motogram/api",
  "version": "0.0.0",
  "private": true,
  "description": "Motogram Backend API (NestJS + Prisma + PostgreSQL/PostGIS + Redis) — Spec 3.1",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && pnpm run build:seed",
    "build:seed": "tsc -p tsconfig.seed.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "echo \"[@motogram/api] lint skipped - typecheck covers TS strict + zod\" && exit 0",
    "typecheck": "pnpm run prisma:generate && tsc --noEmit -p tsconfig.json",
    "test": "pnpm run prisma:generate && jest --testPathIgnorePatterns=/contract/ --testPathIgnorePatterns=/e2e/",
    "test:contract": "pnpm run prisma:generate && jest --runInBand --testPathPattern=contract",
    "test:e2e": "pnpm run prisma:generate && jest --runInBand --testPathPattern=e2e",
    "test:e2e:migrate": "pnpm exec prisma migrate deploy",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "clean": "rimraf dist dist-seed .turbo",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "TS_NODE_PROJECT=tsconfig.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"Node\"}' node -r ts-node/register/transpile-only prisma/seed.ts",
    "db:seed:test-users": "TS_NODE_PROJECT=tsconfig.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"Node\"}' node -r ts-node/register/transpile-only prisma/seed-test-users.ts",
    "db:seed:prod": "node dist-seed/seed.js"
  },
  "dependencies": {
    "@motogram/shared": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "expo-server-sdk": "^3.15.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nestjs-zod": "^4.3.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@motogram/config-tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/../test/jest-env.setup.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
