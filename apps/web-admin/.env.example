# Spec 9.5 - Admin paneli cevresel degiskenleri
# Bu dosya git'e commit edilebilir. Gercek .env dosyasi .gitignore'da.

# Backend API base URL (Spec 8.11.3 /v1 prefix'i zorunlu)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/v1

# Zod: true ise API yanitinda sema drift'inde throw (Faz 14 / R12 oncesi genelde false)
# R12: Prod build öncesi true yapılır (warn-only kapanır); docs/DEPLOY_RUNBOOK.md
NEXT_PUBLIC_STRICT_SCHEMA=false

# NextAuth.js yapilandirmasi
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32

# Server-side (opsiyonel) backend erisim icin sabit admin erisim tokeni
# Uretimde her admin kullanici NextAuth Credentials provider ile backend'e
# kimliklenir; bu token sadece server-side fetch icin yedek.
ADMIN_API_SERVICE_TOKEN=
